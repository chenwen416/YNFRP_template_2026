% =========================
% 字体设置
% 需要 fonts/ 目录中有：
% times.ttf, timesbd.ttf, timesi.ttf, timesbi.ttf
% 方正仿宋GBK.ttf, 方正小标宋简体.ttf, 方正楷体GBK.ttf,
% 方正黑体GBK.ttf, 方正黑体简体.ttf
% =========================

\setmainfont[
  Path = fonts/,
  UprightFont = times.ttf,
  BoldFont = timesbd.ttf,
  ItalicFont = timesi.ttf,
  BoldItalicFont = timesbi.ttf,
  Ligatures = TeX
]{times.ttf}

% =========================
% 中文字体设置：使用 \newCJKfontfamily，避免 \CJKfamily 在分组边界处触发 xeCJK 报错
% =========================

% 中文主字体：方正仿宋_GBK
\setCJKmainfont[
  Path = fonts/,
  AutoFakeBold = 1.2,
  AutoFakeSlant = true
]{方正仿宋GBK.ttf}

% 正文：方正仿宋_GBK
\newCJKfontfamily\ynfangsong[
  Path = fonts/,
  AutoFakeBold = 1.2,
  AutoFakeSlant = true
]{方正仿宋GBK.ttf}

% 题名：方正小标宋简体
\newCJKfontfamily\ynxbs[
  Path = fonts/,
  AutoFakeBold = 1.0
]{方正小标宋简体.ttf}

% 一级标题：方正黑体简体
\newCJKfontfamily\ynhei[
  Path = fonts/,
  AutoFakeBold = 1.0
]{方正黑体简体.ttf}

% “附件”二字和表头：方正黑体GBK
\newCJKfontfamily\ynheiGBK[
  Path = fonts/,
  AutoFakeBold = 1.0
]{方正黑体GBK.ttf}

% 提纲标题：方正楷体GBK
\newCJKfontfamily\ynkai[
  Path = fonts/,
  AutoFakeBold = 1.0
]{方正楷体GBK.ttf}

