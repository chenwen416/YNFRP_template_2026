% =========================
% 正文内部 section/subsection/subsubsection 编号逻辑
%
% 逻辑：
%   （一）立项依据：section 从 1.1 开始，subsection 从 1.1.1 开始
%   （二）研究内容：section 从 2.1 开始，subsection 从 2.1.1 开始
%   （三）研究基础：section 从 3.1 开始，subsection 从 3.1.1 开始
%   （四）其他说明：section 从 4.1 开始，subsection 从 4.1.1 开始
%   subsubsection 使用 （a）（b）（c） 编号
% =========================

\setcounter{secnumdepth}{3}
\setcounter{tocdepth}{3}

% 当前官方提纲大节编号：
% 1 = （一）立项依据
% 2 = （二）研究内容
% 3 = （三）研究基础
% 4 = （四）其他需要说明的情况
\newcounter{YNmajor}

% 进入每个官方提纲大节时，重置 section/subsection/subsubsection 计数
\newcommand{\YNSetMajor}[1]{%
  \setcounter{YNmajor}{#1}%
  \setcounter{section}{0}%
  \setcounter{subsection}{0}%
  \setcounter{subsubsection}{0}%
}

% 编号格式
\renewcommand{\thesection}{\arabic{YNmajor}.\arabic{section}}
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}
\renewcommand{\thesubsubsection}{（\alph{subsubsection}）}

% section/subsection/subsubsection 的显示格式
% 这里统一使用正文仿宋三号加粗，缩进 2em，避免 LaTeX 默认标题过大
\titleformat{\section}
  {\YNBodyFont\bfseries}
  {\thesection}
  {0.5em}
  {}

\titleformat{\subsection}
  {\YNBodyFont\bfseries}
  {\thesubsection}
  {0.5em}
  {}

\titleformat{\subsubsection}
  {\YNBodyFont\bfseries}
  {\thesubsubsection}
  {0.5em}
  {}

% 标题前后间距，可按 Word 效果微调
\titlespacing*{\section}
  {2em}{0.4\baselineskip}{0.2\baselineskip}

\titlespacing*{\subsection}
  {2em}{0.3\baselineskip}{0.1\baselineskip}

\titlespacing*{\subsubsection}
  {2em}{0.2\baselineskip}{0.1\baselineskip}

