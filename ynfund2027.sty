% =========================
% 固定段落/标题命令：稳定版本
% 核心思路：
%   把 \par 放进字体分组内部，使 xeCJK 不会在中文标点后
%   立刻遇到右花括号，从而避免 Too many }'s。
% =========================

\DeclareRobustCommand{\YNMainHeading}[1]{%
  \par
  {%
    \noindent\hskip 2em%
    \YNMainFont #1%
    \par
  }%
}

\DeclareRobustCommand{\YNMainHeadingInline}[2]{%
  \par
  {%
    \noindent\hskip 2em%
    \YNMainFont #1%
    \YNBodyFont #2%
    \par
  }%
}

\DeclareRobustCommand{\YNOutlineHeading}[1]{%
  \par
  {%
    \noindent\hskip 2em%
    \YNOutlineFont #1%
    \par
  }%
}

\DeclareRobustCommand{\YNFixedPara}[1]{%
  \par
  {%
    \noindent\hskip 2em%
    \YNBodyFont #1%
    \par
  }%
}

\DeclareRobustCommand{\YNFixedSubItem}[1]{%
  \par
  {%
    \noindent\hskip 2em%
    \YNBodyFont #1%
    \par
  }%
}

\DeclareRobustCommand{\YNFixedOneLinePara}[1]{%
  \par
  {%
    \noindent\hskip 2em%
    \makebox[0pt][l]{\YNBodyFont #1\hbox{}}%
    \par
  }%
}



